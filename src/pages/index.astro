---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    name: 'Fantasy Name Generator',
    description: 'Generate magical, mythical, and heroic names for your stories, characters, and tabletop RPG games.',
    href: '/fantasy-name-generator',
    icon: `<svg class="w-8 h-8 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>`
  },
  {
    name: 'Baby Name Generator',
    description: 'Find the perfect, meaningful name for your little bundle of joy. Filter by gender or generate unisex options.',
    href: '/baby-name-generator',
    icon: `<svg class="w-8 h-8 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 9h-1m14.071-7.071l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>`
  },
  {
    name: 'Business Name Generator',
    description: 'Discover catchy, professional, and highly brandable names for your new venture, product, or startup.',
    href: '/business-name-generator',
    icon: `<svg class="w-8 h-8 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4.674 12.89a3.001 3.001 0 11-2.674-2.674M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
  },
  {
    name: 'Username Generator',
    description: 'Create unique, cool, and memorable handles for Twitch, YouTube, Discord, Instagram, or gaming profiles.',
    href: '/username-generator',
    icon: `<svg class="w-8 h-8 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>`
  },
  {
    name: 'Pet Name Generator',
    description: 'Explore adorable, funny, and unique matching names for your dog, puppy, kitten, cat, or exotic pets.',
    href: '/pet-name-generator',
    icon: `<svg class="w-8 h-8 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h.01M16.24 7.76a6 6 0 010 8.49m-8.49-.01a6 6 0 010-8.49m11.31-2.82a10 10 0 010 14.14M4.24 4.24a10 10 0 000 14.14M12 14a3 3 0 100-6 3 3 0 000 6z"></path></svg>`
  },
  {
    name: 'Viking Name Generator',
    description: 'Unearth fierce, traditional, and historical Norse warrior and shieldmaiden names inspired by mythology.',
    href: '/viking-name-generator',
    icon: `<svg class="w-8 h-8 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>`
  }
];
---

<Layout 
  title="Free Name Generator - Magic, Baby, Business, Viking & Usernames"
  description="Generate thousands of free, creative names instantly. Filter by gender or format, copy to clipboard, save favourites, and share links with friends."
>
  <div class="space-y-16">
    <!-- Hero Section -->
    <section class="text-center max-w-2xl mx-auto space-y-4 pt-4 md:pt-8">
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-[#111111] dark:text-white leading-none">
        Free Name Generator
      </h1>
      <p class="text-lg md:text-xl text-[#666666] dark:text-[#888888] font-normal leading-relaxed">
        Instantly discover, customize, and save the perfect names for babies, fantasy characters, Viking legends, companies, or social media handles.
      </p>
    </section>

    <!-- Categories Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {categories.map(cat => (
        <a 
          href={cat.href}
          class="block bg-[#f9f9f9] dark:bg-[#111111] border border-[#e5e7eb] dark:border-[#222222] rounded-lg p-6 group hover:border-brand-blue dark:hover:border-brand-blue hover:shadow-sm transition-all duration-200 theme-transition"
        >
          <div class="space-y-4">
            <div class="flex items-center space-x-3">
              <div class="p-2 bg-brand-blue/10 rounded-md" set:html={cat.icon} />
              <h2 class="text-lg font-bold text-[#111111] dark:text-white group-hover:text-brand-blue transition-colors duration-150">
                {cat.name}
              </h2>
            </div>
            <p class="text-sm text-[#666666] dark:text-[#888888] leading-relaxed">
              {cat.description}
            </p>
            <div class="flex items-center space-x-1.5 text-xs font-semibold text-brand-blue pt-2 group-hover:underline">
              <span>Start Generating</span>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </section>

    <!-- Features / Value Prop -->
    <section class="border-t border-[#e5e7eb] dark:border-[#222222] pt-16 grid grid-cols-1 md:grid-cols-3 gap-8 text-center max-w-4xl mx-auto theme-transition">
      <div class="space-y-2">
        <h3 class="font-bold text-[#111111] dark:text-white">Pure Javascript</h3>
        <p class="text-sm text-[#666666] dark:text-[#888888] leading-relaxed">Runs entirely in your browser. Lightning-fast name generation with zero network lag or latency.</p>
      </div>
      <div class="space-y-2">
        <h3 class="font-bold text-[#111111] dark:text-white">Save Favourites</h3>
        <p class="text-sm text-[#666666] dark:text-[#888888] leading-relaxed">Click the heart to save your favorite ideas. Saved names persist on your device using localStorage.</p>
      </div>
      <div class="space-y-2">
        <h3 class="font-bold text-[#111111] dark:text-white">Easy Sharing</h3>
        <p class="text-sm text-[#666666] dark:text-[#888888] leading-relaxed">Share unique links with co-founders, parents, or players to show them exactly what name you found.</p>
      </div>
    </section>
  </div>
</Layout>
